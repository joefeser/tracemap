{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "legacy-sample-smoke-catalog.v1.schema.json",
  "title": "Legacy Sample Smoke Catalog",
  "type": "object",
  "required": [
    "catalogId",
    "entries",
    "generatedFrom",
    "safety",
    "schemaVersion"
  ],
  "properties": {
    "schemaVersion": {
      "const": "legacy-sample-smoke-catalog.v1"
    },
    "catalogId": {
      "const": "legacy-sample-smoke-catalog"
    },
    "generatedFrom": {
      "type": "object",
      "required": [
        "generatedAt",
        "kind",
        "toolVersion"
      ],
      "properties": {
        "kind": {
          "const": "manual-reviewed-metadata"
        },
        "toolVersion": {
          "const": "legacy-sample-smoke-catalog.v1"
        },
        "generatedAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        }
      },
      "additionalProperties": false
    },
    "safety": {
      "type": "object",
      "required": [
        "classification",
        "limitations",
        "redactionProfile",
        "validatorVersion"
      ],
      "properties": {
        "classification": {
          "enum": [
            "hidden",
            "demo-safe",
            "public-safe"
          ]
        },
        "validatorVersion": {
          "const": "legacy-sample-smoke-catalog-validator.v1"
        },
        "redactionProfile": {
          "enum": [
            "catalog-metadata-only"
          ]
        },
        "limitations": {
          "$ref": "#/$defs/limitations"
        }
      },
      "additionalProperties": false
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "safeId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "claimLevel": {
      "enum": [
        "hidden",
        "demo-safe",
        "public-safe"
      ]
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "$ref": "#/$defs/safeId"
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "entry": {
      "type": "object",
      "required": [
        "claimLevel",
        "displayName",
        "families",
        "limitations",
        "relationships",
        "sampleLabel",
        "source",
        "validation"
      ],
      "properties": {
        "sampleLabel": {
          "$ref": "#/$defs/safeId"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "claimLevel": {
          "$ref": "#/$defs/claimLevel"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/family"
          }
        },
        "validation": {
          "$ref": "#/$defs/validation"
        },
        "relationships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relationship"
          }
        },
        "limitations": {
          "$ref": "#/$defs/limitations"
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": [
        "classification",
        "commitIdentity",
        "identityKind",
        "reviewed",
        "safeSourceAlias"
      ],
      "properties": {
        "classification": {
          "enum": [
            "synthetic-fixture",
            "public-repo",
            "public-archive",
            "public-doc-sample",
            "private-local",
            "operator-local",
            "unknown"
          ]
        },
        "identityKind": {
          "enum": [
            "neutral-label",
            "safe-public-alias",
            "category-only"
          ]
        },
        "safeSourceAlias": {
          "$ref": "#/$defs/safeId"
        },
        "reviewed": {
          "type": "boolean"
        },
        "commitIdentity": {
          "type": "object",
          "required": [
            "kind",
            "limitations",
            "shaPresent"
          ],
          "properties": {
            "kind": {
              "enum": [
                "public-sha",
                "fixture-version",
                "category-only"
              ]
            },
            "value": {
              "type": "string"
            },
            "shaPresent": {
              "type": "boolean"
            },
            "limitations": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "code",
                  "message"
                ],
                "properties": {
                  "code": {
                    "$ref": "#/$defs/safeId"
                  },
                  "message": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "family": {
      "type": "object",
      "required": [
        "expectedCoverageLabels",
        "expectedEvidenceTiers",
        "expectedRuleIds",
        "familyId",
        "limitations",
        "statesAllowed",
        "expectation"
      ],
      "properties": {
        "familyId": {
          "enum": [
            "wcf-service-reference",
            "wcf-config-endpoint-shape",
            "remoting-registration",
            "remoting-channel-config",
            "webforms-event-binding",
            "webforms-markup-codebehind",
            "dbml-linq-to-sql",
            "edmx-entity-framework",
            "typed-dataset",
            "legacy-sql-or-query-surface",
            "build-environment-diagnostics",
            "msbuild-project-load-failure",
            "packages-config",
            "binding-redirects",
            "large-repo-stress",
            "fallback-syntax-scan",
            "analysis-gap-reporting"
          ]
        },
        "expectation": {
          "enum": [
            "required",
            "optional",
            "exploratory"
          ]
        },
        "expectedRuleIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/safeRuleId"
          }
        },
        "expectedEvidenceTiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "Tier1Semantic",
              "Tier2Structural",
              "Tier3SyntaxOrTextual",
              "Tier4Unknown"
            ]
          }
        },
        "expectedCoverageLabels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "expectedExtractors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extractorGapCodes": {
          "type": "array",
          "items": {
            "enum": [
              "extractor-not-available",
              "extractor-deferred",
              "extractor-unsupported",
              "extractor-reduced-coverage"
            ]
          }
        },
        "statesAllowed": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "observed",
              "expected-not-yet-run",
              "reduced",
              "analysis-gap",
              "unsupported",
              "deferred",
              "truncated",
              "rejected"
            ]
          }
        },
        "timeoutBucket": {
          "enum": [
            "small",
            "medium",
            "large",
            "extra-large",
            "operator-defined"
          ]
        },
        "artifactSizeBucket": {
          "enum": [
            "small",
            "medium",
            "large",
            "extra-large",
            "operator-defined"
          ]
        },
        "limitations": {
          "$ref": "#/$defs/limitations"
        }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": [
        "commandTemplates",
        "gates"
      ],
      "properties": {
        "commandTemplates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "artifactSizeBucket",
              "expectedArtifacts",
              "mode",
              "name",
              "template",
              "timeoutBucket"
            ],
            "properties": {
              "name": {
                "$ref": "#/$defs/safeId"
              },
              "template": {
                "type": "string"
              },
              "mode": {
                "enum": [
                  "checked-in-sample",
                  "operator-local",
                  "redacted-artifact-only"
                ]
              },
              "timeoutBucket": {
                "type": "string"
              },
              "artifactSizeBucket": {
                "type": "string"
              },
              "expectedArtifacts": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "gates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "relationship": {
      "type": "object",
      "required": [
        "artifactKind",
        "claimLevel",
        "safeArtifactId",
        "schemaVersion",
        "spec",
        "validationStatus"
      ],
      "properties": {
        "spec": {
          "$ref": "#/$defs/safeId"
        },
        "artifactKind": {
          "enum": [
            "redacted-validation-summary",
            "redacted-baseline-snapshot",
            "redacted-comparison-report",
            "evidence-pack-summary"
          ]
        },
        "schemaVersion": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*\\.v\\d+$"
        },
        "safeArtifactId": {
          "$ref": "#/$defs/safeId"
        },
        "claimLevel": {
          "$ref": "#/$defs/claimLevel"
        },
        "validationStatus": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "safeRuleId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*\\.v\\d+$"
    }
  }
}
