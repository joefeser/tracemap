<configuration>
  <system.runtime.remoting>
    <application name="synthetic-remoting-app">
      <channels>
        <channel ref="tcp" port="synthetic-port" />
        <serverProviders>
          <formatter ref="binary" typeFilterLevel="Full" />
        </serverProviders>
      </channels>
      <service>
        <wellknown type="TraceMap.Samples.LegacyRemoting.RemotingService, RemotingSample" objectUri="synthetic-object-uri" mode="Singleton" />
      </service>
      <client>
        <wellknown type="TraceMap.Samples.LegacyRemoting.RemotingService, RemotingSample" url="tcp://synthetic.invalid/synthetic-object-uri" />
      </client>
    </application>
  </system.runtime.remoting>
</configuration>
