{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tracemap.tools/contracts/scan-manifest.v1.schema.json",
  "title": "TraceMap scan manifest v1",
  "type": "object",
  "required": [
    "scanId",
    "repoName",
    "commitSha",
    "scannerVersion",
    "scannedAt",
    "analysisLevel",
    "buildStatus",
    "knownGaps"
  ],
  "properties": {
    "scanId": { "type": "string", "minLength": 1 },
    "repoName": { "type": "string", "minLength": 1 },
    "remoteUrl": { "type": ["string", "null"] },
    "branch": { "type": ["string", "null"] },
    "commitSha": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
    "scannerVersion": { "type": "string", "minLength": 1 },
    "scannedAt": { "type": "string", "format": "date-time" },
    "analysisLevel": { "type": "string", "minLength": 1 },
    "buildStatus": { "type": "string", "minLength": 1 },
    "solutions": { "type": "array", "items": { "type": "string" } },
    "projects": { "type": "array", "items": { "type": "string" } },
    "targetFrameworks": { "type": "array", "items": { "type": "string" } },
    "knownGaps": { "type": "array", "items": { "type": "string" } },
    "extractorVersions": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
