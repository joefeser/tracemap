{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tracemap.tools/contracts/sql-validation-plan.v1.schema.json",
  "title": "TraceMap SQL validation plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactId", "repository", "commitSha", "observedAt", "expiresAt", "targetContext", "checks"],
  "properties": {
    "schemaVersion": { "const": "sql-validation-plan/v1" },
    "artifactId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,95}$" },
    "repository": { "type": "string", "pattern": "^[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)?$" },
    "commitSha": { "type": "string", "pattern": "^[0-9a-f]{40,64}$" },
    "observedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "targetContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "serverRole", "databaseRole", "schemaRole", "executionMode"],
      "properties": {
        "engine": { "const": "postgresql" },
        "serverRole": { "enum": ["admin", "source", "archive-target", "application-primary", "co-located", "validation"] },
        "databaseRole": { "enum": ["admin", "source-data", "archive-data", "application-data", "validation-only"] },
        "schemaRole": { "enum": ["extension", "application", "archive", "validation", "unspecified"] },
        "executionMode": { "enum": ["manual", "scheduled", "validation-only", "migration-runner"] }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "expectedMajor"],
            "properties": {
              "code": { "const": "postgres.server-version-compatible" },
              "expectedMajor": { "type": "integer", "minimum": 10, "maximum": 99 }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "identifiers"],
            "properties": {
              "code": { "const": "postgres.required-extension-available" },
              "identifiers": {
                "type": "array",
                "minItems": 1,
                "maxItems": 32,
                "uniqueItems": true,
                "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,62}$" }
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "identifiers"],
            "properties": {
              "code": { "const": "postgres.migration-schema-present" },
              "identifiers": {
                "type": "array",
                "minItems": 1,
                "maxItems": 32,
                "uniqueItems": true,
                "items": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_$]{0,62}\\.[A-Za-z_][A-Za-z0-9_$]{0,62}$" }
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "identifiers"],
            "properties": {
              "code": { "const": "postgres.permission-probe-authorized" },
              "identifiers": {
                "type": "array",
                "minItems": 1,
                "maxItems": 32,
                "uniqueItems": true,
                "items": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_$]{0,62}$" }
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "identifiers"],
            "properties": {
              "code": { "const": "postgres.archive-function-callable" },
              "identifiers": {
                "type": "array",
                "minItems": 1,
                "maxItems": 32,
                "uniqueItems": true,
                "items": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_$]{0,62}\\.[A-Za-z_][A-Za-z0-9_$]{0,62}\\([A-Za-z0-9_ ,\\[\\]]{0,120}\\)$" }
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "identifiers"],
            "properties": {
              "code": { "const": "postgres.scheduled-job-registered" },
              "identifiers": {
                "type": "array",
                "minItems": 1,
                "maxItems": 32,
                "uniqueItems": true,
                "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._ -]{0,127}$" }
              }
            }
          }
        ]
      }
    }
  }
}
